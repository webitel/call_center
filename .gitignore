# Dependency directories (remove the comment below to include it)
# vendor/

# Build output
build
dist/
/pkg/
artifacts/
work/
out/

# Core / memory dumps (may contain secrets from process memory)
core
core.*
*.core
*.dmp
*.stackdump
hs_err_pid*.log

# Go profiling output (may contain memory contents)
*.prof
*.pprof
cpu.prof
mem.prof
block.prof
mutex.prof
*.trace

